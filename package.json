{
  "name": "winmdpdf",
  "version": "1.1.0",
  "description": "mdPDF desktop app",
  "author": "ibrahimokdadov",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev:next": "npm run dev --prefix renderer",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "npm run build --prefix renderer",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run build:next && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "test:electron": "jest --config jest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0"
  }
}
