{
  "name": "winmdpdf",
  "version": "1.0.0",
  "description": "mdPDF desktop app",
  "main": "electron/dist/main.js",
  "workspaces": ["renderer"],
  "scripts": {
    "dev:next": "cd renderer && next dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "cd renderer && next build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --outdir=electron/dist --tsconfig=electron/tsconfig.json",
    "build": "npm run build:next && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "test:electron": "jest --config jest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5",
    "wait-on": "^7.2.0"
  }
}
