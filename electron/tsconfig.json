{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../renderer/*"]
    }
  },
  "include": ["../electron/**/*.ts"],
  "exclude": ["../electron/dist", "../renderer", "../node_modules"]
}
